{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Format Code",
      "type": "shell",
      "command": "dart format lib test",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Analyze Code",
      "type": "shell",
      "command": "flutter analyze",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "flutter test",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "flutter test --coverage",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Quality Check (Format + Analyze + Test)",
      "dependsOn": [
        "Format Code",
        "Analyze Code",
        "Run Tests"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
